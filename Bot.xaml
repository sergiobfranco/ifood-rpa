    <jwe:Execute_Javascript DisplayName="Execute_Javascript: Selecionar PV" sap2010:WorkflowViewState.IdRef="Execute_Javascript_4" code="&quot;&quot;&quot;&#xD;&#xA;// Abordagem mais direta - tenta manipular o select diretamente&#xD;&#xA;setTimeout(function() {&#xD;&#xA;    // Encontrar o select original (que está oculto)&#xD;&#xA;    var selectOriginal = document.querySelector('select[id=&quot;aditional-options-2155-input&quot;]');&#xD;&#xA;    &#xD;&#xA;    if (selectOriginal) {&#xD;&#xA;        // Procurar a opção com o texto desejado&#xD;&#xA;        for(var i = 0; i &lt; selectOriginal.options.length; i++) {&#xD;&#xA;            if(selectOriginal.options[i].text.includes('Adriana Karam')) {&#xD;&#xA;                // Selecionar a opção&#xD;&#xA;                selectOriginal.selectedIndex = i;&#xD;&#xA;                &#xD;&#xA;                // Disparar eventos para atualizar a interface&#xD;&#xA;                var event = new Event('change', { bubbles: true });&#xD;&#xA;                selectOriginal.dispatchEvent(event);&#xD;&#xA;                &#xD;&#xA;                event = new Event('input', { bubbles: true });&#xD;&#xA;                selectOriginal.dispatchEvent(event);&#xD;&#xA;                &#xD;&#xA;                // Tentar atualizar o componente Kendo UI&#xD;&#xA;                if (typeof $(selectOriginal).data('kendoDropDownList') !== 'undefined') {&#xD;&#xA;                    $(selectOriginal).data('kendoDropDownList').value(selectOriginal.options[i].value);&#xD;&#xA;                    $(selectOriginal).data('kendoDropDownList').trigger('change');&#xD;&#xA;                }&#xD;&#xA;                &#xD;&#xA;                console.log('Selecionado: Adriana Karam');&#xD;&#xA;                break;&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;    } else {&#xD;&#xA;        console.log('Select não encontrado');&#xD;&#xA;    }&#xD;&#xA;}, 1000);&#xD;&#xA;&quot;&quot;&quot;" inBrowser="webBot" />
